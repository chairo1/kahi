              <ellipse cx="130" cy="98" rx="12" ry="6" fill="#3d6b4a" transform="rotate(15 130 98)"/>
              <!-- seeds -->
              <circle cx="105" cy="82" r="2" fill="#e8c4a0"/>
              <circle cx="111" cy="86" r="1.5" fill="#e8c4a0"/>
              <circle cx="88" cy="80" r="2" fill="#e8c4a0"/>
              <!-- herbs on top -->
              <path d="M100 70 Q95 60 90 55 Q95 60 98 50" stroke="#6aaa7a" stroke-width="1.5" fill="none"/>
              <path d="M100 70 Q105 58 112 52" stroke="#4a8a5c" stroke-width="1.5" fill="none"/>
              <circle cx="90" cy="55" r="4" fill="#6aaa7a" opacity="0.8"/>
