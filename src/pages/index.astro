<!DOCTYPE html>
<html lang="az">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Kahı — Sağlam Menu</title>
<style>
@font-face {
  font-family: 'Articula';
  src: url('data:font/opentype;base64,') format('opentype');
  font-weight: 400;
  font-style: normal;
}
@font-face {
  font-family: 'Articula';
  src: url('data:font/opentype;base64,') format('opentype');
  font-weight: 300;
  font-style: normal;
}
</style>
<style>
:root {
  --sage:       #b8c9a0;
  --sage-dark:  #4a6741;
  --forest:     #3a5535;
  --forest-deep:#2b3f28;
  --cream:      #f4f5ef;
  --cream-warm: #ebe8e0;
  --terra:      #c4763e;
  --terra-lt:   #e8c4a0;
  --white:      #fafaf7;
  --charcoal:   #1e1e1a;
  --text:       #2e2e28;
  --muted:      #7a7a6a;
  --ff: 'Articula', 'Helvetica Neue', Arial, sans-serif;
  --ease: cubic-bezier(0.16,1,0.3,1);
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{font-family:var(--ff);background:var(--white);color:var(--text);overflow-x:hidden;cursor:none}
img{display:block;max-width:100%}
a{text-decoration:none;color:inherit}
ul{list-style:none}

/* cursor */
.cur{position:fixed;width:8px;height:8px;background:var(--sage-dark);border-radius:50%;pointer-events:none;z-index:9999;transform:translate(-50%,-50%);transition:width .3s,height .3s,background .3s;mix-blend-mode:multiply}
.cur-r{position:fixed;width:36px;height:36px;border:1.5px solid var(--sage-dark);border-radius:50%;pointer-events:none;z-index:9998;transform:translate(-50%,-50%);transition:left .15s var(--ease),top .15s var(--ease),width .3s,height .3s;opacity:.5}
.cur.h{width:14px;height:14px;background:var(--terra)}
.cur-r.h{width:48px;height:48px;opacity:.25}

/* reveal */
.rv{opacity:0;transform:translateY(28px);transition:opacity .85s var(--ease),transform .85s var(--ease)}
.rv.on{opacity:1;transform:none}
.rl{opacity:0;transform:translateX(-32px);transition:opacity .85s var(--ease),transform .85s var(--ease)}
.rl.on{opacity:1;transform:none}
.rr{opacity:0;transform:translateX(32px);transition:opacity .85s var(--ease),transform .85s var(--ease)}
.rr.on{opacity:1;transform:none}

/* nav */
nav{position:fixed;top:0;left:0;right:0;z-index:900;display:flex;align-items:center;justify-content:space-between;padding:20px 56px;transition:background .4s,padding .4s,box-shadow .4s}
nav.sc{background:rgba(244,245,239,.9);backdrop-filter:blur(16px);padding:12px 56px;box-shadow:0 1px 0 rgba(74,103,65,.1)}
.nav-logo img{height:46px;width:46px;object-fit:contain;border-radius:10px}
.nav-links{display:flex;gap:32px;align-items:center}
.nav-links a{font-size:.75rem;font-weight:400;letter-spacing:.14em;text-transform:uppercase;color:var(--cream);position:relative;padding-bottom:2px}
nav.sc .nav-links a{color:var(--forest)}
.nav-links a::after{content:'';position:absolute;bottom:0;left:0;width:0;height:1px;background:var(--terra);transition:width .3s var(--ease)}
.nav-links a:hover::after{width:100%}
.nav-btn{background:var(--terra);color:var(--white);padding:10px 24px;border-radius:100px;font-size:.75rem;font-weight:400;letter-spacing:.1em;text-transform:uppercase;transition:background .3s,transform .2s}
.nav-btn:hover{background:#d4834a;transform:translateY(-1px)}
.nav-btn::after{display:none!important}

/* hero */
#hero{min-height:100vh;background:var(--forest);display:flex;flex-direction:column;overflow:hidden;position:relative}
.hero-bg{position:absolute;inset:0;background:radial-gradient(ellipse 70% 60% at 65% 50%,rgba(74,103,65,.25) 0%,transparent 60%),radial-gradient(ellipse 40% 50% at 15% 80%,rgba(196,118,62,.1) 0%,transparent 55%)}
.hero-lines{position:absolute;right:0;top:0;bottom:0;width:45%;opacity:.06;pointer-events:none}
.hero-body{position:relative;z-index:2;flex:1;display:flex;align-items:center;padding:130px 56px 80px;max-width:1300px;margin:0 auto;width:100%;gap:64px}
.hero-left{flex:1;min-width:0}
.hero-badge{display:inline-flex;align-items:center;gap:8px;background:rgba(184,201,160,.1);border:1px solid rgba(184,201,160,.22);padding:6px 16px;border-radius:100px;font-size:.68rem;font-weight:400;letter-spacing:.16em;text-transform:uppercase;color:var(--sage);margin-bottom:26px;animation:fd .9s var(--ease) .1s both}
.hero-dot{width:5px;height:5px;background:var(--terra-lt);border-radius:50%;animation:pulse 2s infinite}
@keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.4;transform:scale(.6)}}
h1.hero-title{font-size:clamp(3rem,6.5vw,5.5rem);font-weight:300;line-height:1.07;color:var(--cream);letter-spacing:-.01em;animation:fd .9s var(--ease) .25s both}
h1.hero-title em{font-style:italic;color:var(--terra-lt)}
.hero-sub{margin-top:22px;font-size:.98rem;font-weight:300;color:rgba(184,201,160,.72);line-height:1.75;max-width:400px;animation:fd .9s var(--ease) .4s both}
.hero-actions{display:flex;gap:14px;align-items:center;margin-top:40px;animation:fd .9s var(--ease) .55s both}
.btn-p{background:var(--terra);color:var(--white);padding:14px 32px;border-radius:100px;font-size:.78rem;font-weight:400;letter-spacing:.1em;text-transform:uppercase;transition:background .3s,transform .2s,box-shadow .3s}
.btn-p:hover{background:#d4834a;transform:translateY(-2px);box-shadow:0 12px 32px rgba(196,118,62,.3)}
.btn-ghost{display:flex;align-items:center;gap:10px;color:rgba(184,201,160,.75);font-size:.78rem;font-weight:300;letter-spacing:.08em;transition:color .3s,gap .3s var(--ease)}
.btn-ghost:hover{color:var(--sage);gap:16px}
.btn-ghost-arr{width:34px;height:34px;border:1px solid rgba(184,201,160,.25);border-radius:50%;display:flex;align-items:center;justify-content:center;transition:border-color .3s,transform .3s}
.btn-ghost:hover .btn-ghost-arr{border-color:var(--sage);transform:rotate(45deg)}
.hero-stats{display:flex;gap:36px;margin-top:60px;padding-top:36px;border-top:1px solid rgba(184,201,160,.1);animation:fd .9s var(--ease) .7s both}
.stat-n{font-size:2rem;font-weight:300;color:var(--cream);line-height:1}
.stat-l{font-size:.68rem;font-weight:400;letter-spacing:.12em;text-transform:uppercase;color:rgba(184,201,160,.5);margin-top:4px}

/* hero right - bowl image */
.hero-right{flex:0 0 460px;height:540px;position:relative;animation:floatAnim 6s ease-in-out infinite}
@keyframes floatAnim{0%,100%{transform:translateY(0)}50%{transform:translateY(-14px)}}
.bowl-wrap{position:absolute;inset:0;border-radius:50% 50% 46% 54% / 54% 46% 54% 46%;overflow:hidden;border:2px solid rgba(184,201,160,.2);box-shadow:0 40px 100px rgba(0,0,0,.4),0 0 0 1px rgba(184,201,160,.08)}
.bowl-wrap img{width:100%;height:100%;object-fit:cover;transform:scale(1.05)}
.hero-tag{position:absolute;background:rgba(244,245,239,.93);border-radius:100px;padding:8px 16px;font-size:.68rem;font-weight:400;letter-spacing:.1em;text-transform:uppercase;color:var(--forest);backdrop-filter:blur(8px);white-space:nowrap;box-shadow:0 8px 24px rgba(0,0,0,.15)}
.ht1{top:18%;left:-28px;animation:ft 7s ease-in-out infinite}
.ht2{bottom:26%;right:-18px;animation:ft 6s ease-in-out 1s infinite}
.ht3{top:62%;left:-10px;animation:ft 8s ease-in-out 2s infinite}
@keyframes ft{0%,100%{transform:translateY(0) rotate(-1deg)}50%{transform:translateY(-8px) rotate(1deg)}}
@keyframes fd{from{opacity:0;transform:translateY(-16px)}to{opacity:1;transform:none}}

.hero-scroll{position:relative;z-index:2;display:flex;align-items:center;gap:12px;padding:0 56px 36px;color:rgba(184,201,160,.35);font-size:.65rem;letter-spacing:.16em;text-transform:uppercase;animation:fd .9s var(--ease) 1.1s both}
.hero-scroll-line{width:44px;height:1px;background:linear-gradient(to right,rgba(184,201,160,.35),transparent)}

/* marquee */
.marquee{background:var(--terra);padding:13px 0;overflow:hidden}
.marquee-t{display:flex;animation:mq 24s linear infinite;white-space:nowrap}
.marquee-t span{font-size:.7rem;font-weight:400;letter-spacing:.18em;text-transform:uppercase;color:var(--white);padding:0 32px}
.marquee-t .dot{color:rgba(255,255,255,.4);padding:0 4px}
@keyframes mq{from{transform:translateX(0)}to{transform:translateX(-50%)}}

/* section commons */
section{position:relative}
.wrap{max-width:1160px;margin:0 auto;padding:0 56px}
.sec-label{font-size:.68rem;font-weight:400;letter-spacing:.2em;text-transform:uppercase;color:var(--terra);display:flex;align-items:center;gap:10px;margin-bottom:16px}
.sec-label::before{content:'';width:24px;height:1px;background:var(--terra)}
h2.sec-title{font-size:clamp(2rem,4vw,3.4rem);font-weight:300;line-height:1.12;color:var(--forest);letter-spacing:-.01em}
h2.sec-title em{font-style:italic;color:var(--sage-dark)}

/* about */
#about{padding:100px 0;background:var(--white)}
.about-grid{display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:center}
.about-img{position:relative}
.about-img-main{width:100%;aspect-ratio:4/5;border-radius:4px 56px 4px 56px;background:var(--forest);overflow:hidden;display:flex;align-items:center;justify-content:center}
.about-img-art{width:65%;opacity:.55}
.about-badge{position:absolute;bottom:-22px;right:-22px;width:106px;height:106px;background:var(--terra);border-radius:50%;display:flex;flex-direction:column;align-items:center;justify-content:center;color:var(--white);text-align:center}
.about-badge .big{font-size:1.7rem;font-weight:300;line-height:1}
.about-badge .sm{font-size:.58rem;letter-spacing:.08em;text-transform:uppercase;opacity:.85;margin-top:3px}
.about-body{font-size:1rem;font-weight:300;line-height:1.8;color:var(--text);margin-top:22px}
.about-vals{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-top:36px}
.val{background:var(--cream);border:1px solid var(--cream-warm);border-radius:12px;padding:18px;transition:border-color .3s,transform .3s}
.val:hover{border-color:var(--sage);transform:translateY(-3px)}
.val-icon{font-size:1.3rem;margin-bottom:6px}
.val-t{font-size:.78rem;font-weight:400;letter-spacing:.06em;text-transform:uppercase;color:var(--forest);margin-bottom:4px}
.val-d{font-size:.77rem;font-weight:300;color:var(--muted);line-height:1.6}

/* menu */
#menu{padding:100px 0;background:var(--cream)}
.menu-head{display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:48px}
.menu-tabs{display:flex;gap:4px;background:var(--cream-warm);border-radius:100px;padding:4px}
.tab{font-size:.72rem;font-weight:400;letter-spacing:.08em;text-transform:uppercase;color:var(--muted);padding:8px 18px;border-radius:100px;cursor:pointer;transition:background .3s,color .3s}
.tab.on{background:var(--forest);color:var(--cream)}
.menu-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:22px}
.mc{background:var(--white);border:1px solid var(--cream-warm);border-radius:18px;overflow:hidden;transition:transform .4s var(--ease),box-shadow .4s,border-color .3s}
.mc:hover{transform:translateY(-7px);box-shadow:0 22px 56px rgba(42,63,40,.12);border-color:var(--sage)}
.mc-img{aspect-ratio:4/3;position:relative;display:flex;align-items:center;justify-content:center;overflow:hidden}
.mc-tag{position:absolute;top:12px;right:12px;background:var(--terra);color:var(--white);font-size:.62rem;font-weight:400;letter-spacing:.1em;text-transform:uppercase;padding:4px 11px;border-radius:100px}
.mc-body{padding:20px 22px}
.mc-title{font-size:1.2rem;font-weight:300;color:var(--forest);margin-bottom:6px}
.mc-desc{font-size:.78rem;font-weight:300;color:var(--muted);line-height:1.65}
.mc-foot{display:flex;align-items:center;justify-content:space-between;margin-top:16px;padding-top:14px;border-top:1px solid var(--cream-warm)}
.mc-price{font-size:1.15rem;font-weight:300;color:var(--forest)}
.mc-price span{font-size:.7rem;font-weight:300;color:var(--muted)}
.mc-btn{width:32px;height:32px;border-radius:50%;background:var(--forest);display:flex;align-items:center;justify-content:center;color:var(--cream);font-size:1rem;transition:background .3s,transform .3s;cursor:pointer}
.mc-btn:hover{background:var(--terra);transform:rotate(90deg)}
.bg1{background:linear-gradient(135deg,#3a5535,#2b3f28)}
.bg2{background:linear-gradient(135deg,#4a6741,#334d2c)}
.bg3{background:linear-gradient(135deg,#c4763e,#9a5528)}
.bg4{background:linear-gradient(135deg,#5d8050,#3a5535)}
.bg5{background:linear-gradient(135deg,#6a9060,#445e3a)}
.bg6{background:linear-gradient(135deg,#cc7e44,#a05c2c)}
.emoji{font-size:3.2rem}

/* why */
#why{padding:100px 0;background:var(--forest-deep);overflow:hidden}
.why-head .sec-label{color:rgba(184,201,160,.5)}
.why-head .sec-label::before{background:rgba(184,201,160,.5)}
.why-head h2{color:var(--cream)}
.why-head h2 em{color:var(--terra-lt)}
.why-grid{display:grid;grid-template-columns:1fr 1fr;gap:72px;align-items:center;margin-top:52px}
.why-features{display:flex;flex-direction:column;gap:20px}
.wf{display:flex;gap:20px;align-items:flex-start;padding:24px;background:rgba(184,201,160,.05);border:1px solid rgba(184,201,160,.09);border-radius:14px;transition:background .3s,border-color .3s,transform .3s;cursor:default}
.wf:hover{background:rgba(184,201,160,.09);border-color:rgba(184,201,160,.18);transform:translateX(7px)}
.wf-icon{width:48px;height:48px;flex-shrink:0;background:rgba(74,103,65,.25);border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:1.3rem}
.wf-t{font-size:.88rem;font-weight:400;color:var(--cream);margin-bottom:5px}
.wf-d{font-size:.78rem;font-weight:300;color:rgba(184,201,160,.55);line-height:1.7}
.why-vis{display:flex;align-items:center;justify-content:center}
.ring-o{width:320px;height:320px;border:1px solid rgba(184,201,160,.1);border-radius:50%;position:relative;display:flex;align-items:center;justify-content:center;animation:spin 40s linear infinite}
.ring-i{width:220px;height:220px;border:1px solid rgba(184,201,160,.15);border-radius:50%;background:rgba(74,103,65,.12);display:flex;align-items:center;justify-content:center;animation:spin 40s linear infinite reverse}
.ring-dot{position:absolute;width:9px;height:9px;background:var(--terra-lt);border-radius:50%;top:-4px;left:50%;transform:translateX(-50%)}
.ring-dot2{top:auto;bottom:-4px;background:var(--sage)}
.ring-txt{font-size:1rem;font-weight:300;color:var(--cream);text-align:center;line-height:1.5;animation:spin 40s linear infinite}
.ring-num{font-size:3rem;font-weight:300;color:var(--sage);display:block}
@keyframes spin{from{transform:rotate(0)}to{transform:rotate(360deg)}}

/* process */
#process{padding:100px 0;background:var(--white)}
.steps{display:grid;grid-template-columns:repeat(4,1fr);gap:28px;margin-top:56px}
.step{text-align:center;position:relative}
.step:not(:last-child)::after{content:'→';position:absolute;top:28px;right:-14px;color:var(--sage);font-size:1.1rem}
.step-n{width:58px;height:58px;border-radius:50%;background:var(--forest);color:var(--cream);font-size:1.3rem;font-weight:300;display:flex;align-items:center;justify-content:center;margin:0 auto 16px;transition:background .3s,transform .3s}
.step:hover .step-n{background:var(--terra);transform:scale(1.1)}
.step-icon{font-size:1.3rem;margin-bottom:12px}
.step-t{font-size:1.1rem;font-weight:300;color:var(--forest);margin-bottom:7px}
.step-d{font-size:.78rem;font-weight:300;color:var(--muted);line-height:1.6}

/* testimonials */
#testi{padding:100px 0;background:var(--cream)}
.testi-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-top:52px}
.tc{background:var(--white);border:1px solid var(--cream-warm);border-radius:18px;padding:28px;transition:transform .4s var(--ease),box-shadow .4s}
.tc:hover{transform:translateY(-5px);box-shadow:0 18px 48px rgba(42,63,40,.1)}
.tc.dark{background:var(--forest);border-color:var(--sage-dark);margin-top:-18px}
.tc-stars{color:var(--terra);font-size:.72rem;margin-bottom:10px}
.tc-q{font-size:2.5rem;font-weight:300;line-height:.5;color:var(--sage);margin-bottom:14px}
.tc.dark .tc-q{color:rgba(184,201,160,.25)}
.tc-txt{font-size:.95rem;font-weight:300;font-style:italic;color:var(--text);line-height:1.7;margin-bottom:20px}
.tc.dark .tc-txt{color:rgba(184,201,160,.8)}
.tc-auth{display:flex;align-items:center;gap:12px}
.tc-av{width:40px;height:40px;border-radius:50%;background:var(--sage);display:flex;align-items:center;justify-content:center;font-size:.9rem}
.tc-name{font-size:.82rem;font-weight:400;color:var(--forest)}
.tc.dark .tc-name{color:var(--cream)}
.tc-role{font-size:.68rem;color:var(--muted);margin-top:1px}
.tc.dark .tc-role{color:rgba(184,201,160,.45)}

/* cta */
#cta{padding:80px 0;background:var(--terra);position:relative;overflow:hidden}
#cta::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 25% 50%,rgba(255,255,255,.08) 0%,transparent 55%)}
.cta-inner{position:relative;z-index:1;display:flex;align-items:center;justify-content:space-between;gap:36px}
.cta-t{font-size:clamp(1.8rem,3.5vw,3rem);font-weight:300;color:var(--white);line-height:1.15}
.cta-t em{font-style:italic}
.cta-sub{font-size:.88rem;font-weight:300;color:rgba(250,250,247,.7);margin-top:10px;max-width:360px}
.cta-btns{display:flex;gap:12px;flex-shrink:0}
.btn-w{background:var(--white);color:var(--terra);padding:13px 28px;border-radius:100px;font-size:.78rem;font-weight:400;letter-spacing:.09em;text-transform:uppercase;transition:background .3s,transform .2s}
.btn-w:hover{background:var(--cream);transform:translateY(-2px)}
.btn-dk{background:rgba(42,63,40,.22);color:var(--white);border:1px solid rgba(250,250,247,.28);padding:13px 28px;border-radius:100px;font-size:.78rem;font-weight:300;letter-spacing:.09em;text-transform:uppercase;transition:background .3s}
.btn-dk:hover{background:rgba(42,63,40,.35)}

/* contact */
#contact{padding:100px 0;background:var(--white)}
.contact-grid{display:grid;grid-template-columns:1fr 1fr;gap:72px;align-items:start;margin-top:52px}
.ci{display:flex;gap:18px;align-items:flex-start;padding:20px;background:var(--cream);border:1px solid var(--cream-warm);border-radius:14px;margin-bottom:14px;transition:border-color .3s,transform .3s}
.ci:hover{border-color:var(--sage);transform:translateX(5px)}
.ci-icon{width:42px;height:42px;flex-shrink:0;background:var(--forest);border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:1rem}
.ci-lbl{font-size:.66rem;font-weight:400;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);margin-bottom:4px}
.ci-val{font-size:.9rem;font-weight:300;color:var(--forest)}
.hours-box{background:var(--forest);border-radius:18px;padding:24px;margin-top:20px}
.hours-title{font-size:.66rem;font-weight:400;letter-spacing:.12em;text-transform:uppercase;color:rgba(184,201,160,.55);margin-bottom:14px}
.hr{display:flex;justify-content:space-between;font-size:.84rem;font-weight:300;color:var(--cream);padding:7px 0;border-bottom:1px solid rgba(184,201,160,.1)}
.hr:last-child{border-bottom:none}
.hr span:last-child{color:var(--terra-lt)}
.map-box{border-radius:18px;overflow:hidden;aspect-ratio:1;background:var(--forest);display:flex;align-items:center;justify-content:center;position:relative}
.map-box-bg{position:absolute;inset:0;background:radial-gradient(circle at 40% 40%,rgba(74,103,65,.35) 0%,transparent 55%),radial-gradient(circle at 70% 70%,rgba(196,118,62,.18) 0%,transparent 40%)}
.map-pin{position:relative;z-index:1;text-align:center}
.map-pin-icon{font-size:2.2rem;animation:pb 2s ease-in-out infinite}
@keyframes pb{0%,100%{transform:translateY(0)}50%{transform:translateY(-9px)}}
.map-pin-lbl{font-size:.95rem;font-weight:300;color:var(--cream);margin-top:10px}
.map-pin-addr{font-size:.74rem;font-weight:300;color:rgba(184,201,160,.55);margin-top:4px;line-height:1.5}

/* footer */
footer{background:var(--charcoal);padding:64px 0 30px}
.ft{display:grid;grid-template-columns:1.8fr 1fr 1fr 1fr;gap:44px;max-width:1160px;margin:0 auto;padding:0 56px 48px;border-bottom:1px solid rgba(255,255,255,.07)}
.ft-logo{display:flex;align-items:center;gap:10px;margin-bottom:14px}
.ft-logo img{height:34px;width:34px;object-fit:contain;border-radius:6px}
.ft-logo-txt{font-size:1.3rem;font-weight:400;color:var(--cream);letter-spacing:.05em}
.ft-desc{font-size:.78rem;font-weight:300;color:rgba(255,255,255,.38);line-height:1.7;max-width:220px}
