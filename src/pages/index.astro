            <span class="btn-outline-arrow">
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
                <path d="M2 10L10 2M10 2H4M10 2V8" stroke="currentColor" stroke-width="1.5"/>
              </svg>
            </span>
          </a>
        </div>
        <div class="hero-stats">
          <div>
            <div class="hero-stat-num">50+</div>
            <div class="hero-stat-label">Menyu seçimi</div>
          </div>
          <div>
            <div class="hero-stat-num">100%</div>
            <div class="hero-stat-label">Təbii məhsullar</div>
          </div>
          <div>
            <div class="hero-stat-num">8–22</div>
            <div class="hero-stat-label">İş saatları</div>
          </div>
        </div>
      </div>
      <div class="hero-right">
        <div class="hero-plate">
          <div class="hero-plate-inner">
            <img src="/bowl.jpg" alt="Kahi Bowl" class="w-full h-full object-cover rounded-full" />
              <!-- bowl -->
              <ellipse cx="100" cy="130" rx="70" ry="20" fill="#1c3a2a" opacity="0.5"/>
              <path d="M30 100 Q30 160 100 165 Q170 160 170 100 Z" fill="#2e5c3e"/>
